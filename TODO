# Example usage:
positions = [
    "8/8/4/R4r/8/8/8/8 w",
    "8/8/8/4r3/8/8/8/8 b",
    "Home",
    "8/8/8/8/8/8/R7/8 w"
]

class PositionNavigator:
    def __init__(self, positions):
        self.positions = list(positions)  
        self.index = 0  # Track position

    def next(self):
        """Move forward but stop at the last element."""
        if self.index < len(self.positions) - 1:
            self.index += 1
        return self.positions[self.index]

    def previous(self):
        """Move backward but stop at the first element."""
        if self.index > 0:
            self.index -= 1
        return self.positions[self.index]

    def current(self):
        """Get the current position."""
        return self.positions[self.index]


navigator = PositionNavigator(positions) # Create the navigator for this FEN_LIST element, load it as a member of the Game.

print(navigator.current())   # "8/8/4/R4r/8/8/8/8 w"
print(navigator.next())      # "8/8/8/4r3/8/8/8/8 b"
print(navigator.next())      # "Home"
print(navigator.next())      # "8/8/8/8/8/8/R7/8 w"
print(navigator.next())      # Stays on last item
print(navigator.previous())  # Moves back to "Home"
print(navigator.previous())  # Moves back again
print(navigator.previous())  # Stays at first item
